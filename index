<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CPA 财务分析工具</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
            background: #1a1a1a;
            height: 100vh;
            overflow: hidden;
            color: #e5e5e5;
        }

        /* 主容器 - 左右分栏 */
        .app-container {
            display: flex;
            height: 100vh;
        }

        /* 左侧边栏 */
        .sidebar {
            width: 280px;
            min-width: 280px;
            background: #252525;
            border-right: 1px solid #333;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* 左侧头部 */
        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid #333;
        }

        .sidebar-header h1 {
            font-size: 18px;
            color: #e5e5e5;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sidebar-header h1 span {
            font-size: 24px;
        }

        /* 新建分析按钮 */
        .new-analysis-btn {
            width: 100%;
            padding: 12px;
            margin-top: 15px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all 0.3s;
        }

        .new-analysis-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        /* 历史记录列表 */
        .history-section {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
        }

        .history-title {
            font-size: 12px;
            color: #999;
            padding: 10px 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .history-list {
            list-style: none;
        }

        .history-item {
            padding: 12px 16px;
            border-radius: 8px;
            cursor: pointer;
            margin-bottom: 4px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .history-item:hover {
            background: #333;
        }

        .history-item.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .history-item .icon {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            background: #333;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .history-item.active .icon {
            background: rgba(255, 255, 255, 0.2);
        }

        .history-item .content {
            flex: 1;
            min-width: 0;
        }

        .history-item .company-name {
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: #e5e5e5;
        }

        .history-item .analysis-time {
            font-size: 12px;
            color: #888;
            margin-top: 2px;
        }

        .history-item.active .analysis-time {
            color: rgba(255, 255, 255, 0.7);
        }

        /* 清空历史按钮 */
        .clear-history {
            padding: 15px 20px;
            border-top: 1px solid #333;
        }

        .clear-history-btn {
            width: 100%;
            padding: 10px;
            background: transparent;
            border: 1px solid #444;
            border-radius: 8px;
            color: #888;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .clear-history-btn:hover {
            background: #333;
            border-color: #555;
            color: #e5e5e5;
        }

        /* 右侧主区域 */
        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #0a0a0a;
            height: 100vh;
            overflow: hidden;
        }

        /* 右侧头部 - 搜索区 */
        .main-header {
            padding: 20px 30px;
            background: #0a0a0a;
            border-bottom: 1px solid #333;
        }

        .search-container {
            display: flex;
            gap: 12px;
            max-width: 800px;
            margin: 0 auto;
        }

        .search-input-wrapper {
            flex: 1;
            position: relative;
        }

        .search-input {
            width: 100%;
            padding: 14px 20px;
            padding-left: 45px;
            border: 2px solid #333;
            border-radius: 12px;
            font-size: 15px;
            transition: all 0.3s;
            background: #1a1a1a;
            color: #e5e5e5;
        }

        .search-input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
        }

        .search-input::placeholder {
            color: #666;
        }

        .search-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #666;
            font-size: 18px;
        }

        .analyze-btn {
            padding: 14px 28px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .analyze-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .analyze-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        /* 配置按钮 */
        .config-btn {
            padding: 14px 20px;
            background: #1a1a1a;
            border: 2px solid #333;
            border-radius: 12px;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.3s;
            color: #e5e5e5;
        }

        .config-btn:hover {
            background: #333;
            border-color: #444;
        }

        /* 内容区域 */
        .content-area {
            flex: 1;
            overflow-y: auto;
            padding: 30px;
            background: #0a0a0a;
        }

        /* 欢迎页面 */
        .welcome-container {
            max-width: 600px;
            margin: 0 auto;
            text-align: center;
            padding-top: 100px;
        }

        .welcome-icon {
            font-size: 64px;
            margin-bottom: 20px;
        }

        .welcome-title {
            font-size: 28px;
            color: #e5e5e5;
            margin-bottom: 12px;
        }

        .welcome-desc {
            font-size: 16px;
            color: #888;
            margin-bottom: 40px;
            line-height: 1.6;
        }

        .quick-actions {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            max-width: 500px;
            margin: 0 auto;
        }

        .quick-action {
            padding: 16px;
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
        }

        .quick-action:hover {
            border-color: #667eea;
            box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
            background: #222;
        }

        .quick-action .company {
            font-size: 15px;
            font-weight: 500;
            color: #e5e5e5;
        }

        .quick-action .code {
            font-size: 12px;
            color: #666;
            margin-top: 4px;
        }

        /* 状态提示 */
        .status-bar {
            padding: 15px 20px;
            margin-bottom: 20px;
            border-radius: 10px;
            display: none;
        }

        .status-bar.show {
            display: block;
        }

        .status-bar.loading {
            background: #1a2332;
            border-left: 4px solid #1976d2;
        }

        .status-bar.error {
            background: #2a1a1a;
            border-left: 4px solid #c62828;
        }

        .status-bar.success {
            background: #1a2a1a;
            border-left: 4px solid #2e7d32;
        }

        /* 分析结果 */
        .result-container {
            max-width: 900px;
            margin: 0 auto;
            background: #1a1a1a;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
            border: 1px solid #333;
        }

        .result-container h1, .result-container h2, .result-container h3 {
            color: #e5e5e5;
            margin-top: 24px;
            margin-bottom: 12px;
        }

        .result-container h1 { 
            font-size: 1.8em; 
            border-bottom: 2px solid #667eea; 
            padding-bottom: 12px;
            margin-top: 0;
        }
        .result-container h2 { 
            font-size: 1.5em; 
            color: #667eea; 
        }
        .result-container h3 { 
            font-size: 1.2em; 
        }

        .result-container p {
            line-height: 1.8;
            color: #b0b0b0;
            margin-bottom: 16px;
        }

        .result-container ul, .result-container ol {
            margin-left: 25px;
            margin-bottom: 16px;
        }

        .result-container li {
            line-height: 1.8;
            color: #b0b0b0;
            margin-bottom: 8px;
        }

        .result-container strong {
            color: #e5e5e5;
        }

        .result-container table {
            width: 100%;
            border-collapse: collapse;
            margin: 16px 0;
        }

        .result-container th, .result-container td {
            border: 1px solid #333;
            padding: 10px 12px;
            text-align: left;
        }

        .result-container th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .result-container td {
            background: #222;
            color: #b0b0b0;
        }

        .result-container tr:nth-child(even) td {
            background: #1a1a1a;
        }

        .result-container a {
            color: #667eea;
            text-decoration: none;
        }

        .result-container a:hover {
            text-decoration: underline;
        }

        .result-container code {
            background: #222;
            padding: 2px 6px;
            border-radius: 4px;
            font-family: 'Courier New', monospace;
            color: #e5e5e5;
        }

        .result-container pre {
            background: #1a1a1a;
            padding: 16px;
            border-radius: 8px;
            overflow-x: auto;
            border: 1px solid #333;
        }

        .result-container pre code {
            background: transparent;
            padding: 0;
        }

        /* 加载动画 */
        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid #333;
            border-top: 3px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-right: 10px;
            vertical-align: middle;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* 配置弹窗 */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal {
            background: #1a1a1a;
            border-radius: 16px;
            width: 500px;
            max-width: 90%;
            border: 1px solid #333;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal-header {
            padding: 20px;
            border-bottom: 1px solid #333;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h2 {
            margin: 0;
            font-size: 18px;
            color: #e5e5e5;
        }

        .modal-close {
            width: 32px;
            height: 32px;
            border: none;
            background: transparent;
            font-size: 24px;
            cursor: pointer;
            color: #666;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-close:hover {
            color: #e5e5e5;
        }

        .modal-body {
            padding: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-weight: 500;
            color: #e5e5e5;
            margin-bottom: 8px;
        }

        .form-group select, .form-group input {
            width: 100%;
            padding: 12px;
            border: 2px solid #333;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.3s;
            background: #222;
            color: #e5e5e5;
        }

        .form-group select:focus, .form-group input:focus {
            outline: none;
            border-color: #667eea;
        }

        .form-group .help-text {
            font-size: 12px;
            color: #666;
            margin-top: 6px;
        }

        .modal-footer {
            padding: 15px 20px;
            border-top: 1px solid #333;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .btn-secondary {
            background: #333;
            color: #e5e5e5;
            border: 1px solid #444;
        }

        .btn-secondary:hover {
            background: #444;
            border-color: #555;
        }

        /* 响应式 */
        @media (max-width: 768px) {
            .sidebar {
                display: none;
            }

            .main-header {
                padding: 15px;
            }

            .search-container {
                flex-wrap: wrap;
            }

            .analyze-btn {
                width: 100%;
            }

            .content-area {
                padding: 15px;
            }

            .result-container {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- 左侧边栏 -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h1><span>📊</span> CPA 财务分析</h1>
                <button class="new-analysis-btn" onclick="newAnalysis()">
                    <span>➕</span> 新建分析
                </button>
            </div>

            <div class="history-section">
                <div class="history-title">历史记录</div>
                <ul class="history-list" id="historyList">
                    <!-- 动态生成历史记录 -->
                </ul>
            </div>

            <div class="clear-history">
                <button class="clear-history-btn" onclick="clearHistory()">
                    🗑️ 清空历史记录
                </button>
            </div>
        </aside>

        <!-- 右侧主区域 -->
        <main class="main-area">
            <!-- 搜索区 -->
            <header class="main-header">
                <div class="search-container">
                    <div class="search-input-wrapper">
                        <span class="search-icon">🔍</span>
                        <input type="text" class="search-input" id="companyInput" 
                               placeholder="输入股票名称或代码，如：贵州茅台、600519"
                               onkeypress="if(event.key==='Enter') startAnalysis()">
                    </div>
                    <button class="analyze-btn" id="analyzeBtn" onclick="startAnalysis()">
                        开始分析
                    </button>
                    <button class="config-btn" onclick="showConfig()">
                        ⚙️
                    </button>
                </div>
            </header>

            <!-- 内容区域 -->
            <div class="content-area">
                <!-- 欢迎页面 -->
                <div class="welcome-container" id="welcomePage">
                    <div class="welcome-icon">📊</div>
                    <h2 class="welcome-title">CPA 财务分析工具</h2>
                    <p class="welcome-desc">
                        专业的上市公司财务分析工具，支持完整的七大章节分析报告。<br>
                        输入股票名称或代码，即可获取专业分析报告。
                    </p>
                    <div class="quick-actions">
                        <div class="quick-action" onclick="quickSearch('贵州茅台')">
                            <div class="company">贵州茅台</div>
                            <div class="code">600519</div>
                        </div>
                        <div class="quick-action" onclick="quickSearch('比亚迪')">
                            <div class="company">比亚迪</div>
                            <div class="code">002594</div>
                        </div>
                        <div class="quick-action" onclick="quickSearch('宁德时代')">
                            <div class="company">宁德时代</div>
                            <div class="code">300750</div>
                        </div>
                        <div class="quick-action" onclick="quickSearch('中国平安')">
                            <div class="company">中国平安</div>
                            <div class="code">601318</div>
                        </div>
                    </div>
                </div>

                <!-- 状态提示 -->
                <div class="status-bar" id="statusBar"></div>

                <!-- 分析结果 -->
                <div class="result-container" id="resultContainer" style="display: none;"></div>
            </div>
        </main>
    </div>

    <!-- 配置弹窗 -->
    <div class="modal-overlay" id="configModal">
        <div class="modal">
            <div class="modal-header">
                <h2>⚙️ API 配置</h2>
                <button class="modal-close" onclick="hideConfig()">×</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>API 类型</label>
                    <select id="apiType" onchange="updateApiConfig()">
                        <option value="openclaw">OpenClaw Gateway（推荐）</option>
                        <option value="anthropic">Anthropic Claude API</option>
                        <option value="openai">OpenAI API</option>
                    </select>
                </div>

                <div class="form-group" id="gatewayGroup">
                    <label>Gateway 地址</label>
                    <input type="text" id="gatewayUrl" placeholder="http://localhost:5000">
                    <p class="help-text">OpenClaw Gateway 的访问地址</p>
                </div>

                <div class="form-group" id="apiKeyGroup" style="display: none;">
                    <label>API Key</label>
                    <input type="password" id="apiKey" placeholder="sk-...">
                    <p class="help-text">你的 API 密钥将保存在本地浏览器中</p>
                </div>

                <div class="form-group" id="modelGroup" style="display: none;">
                    <label>模型选择</label>
                    <select id="modelSelect"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="hideConfig()">取消</button>
                <button class="btn btn-primary" onclick="saveConfig()">保存配置</button>
            </div>
        </div>
    </div>

    <!-- Markdown 解析器 -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <script>
        // 配置管理
        let config = {
            apiType: 'openclaw',
            gatewayUrl: 'http://localhost:5000',
            apiKey: '',
            model: 'claude-3-5-sonnet-20241022'
        };

        let currentCompany = '';

        // 页面初始化
        function init() {
            loadConfig();
            loadHistory();
        }

        // 加载配置
        function loadConfig() {
            const saved = localStorage.getItem('cpa-config');
            if (saved) {
                config = JSON.parse(saved);
                document.getElementById('gatewayUrl').value = config.gatewayUrl || '';
                document.getElementById('apiKey').value = config.apiKey || '';
            }
        }

        // 保存配置
        function saveConfig() {
            config.apiType = document.getElementById('apiType').value;
            config.gatewayUrl = document.getElementById('gatewayUrl').value;
            config.apiKey = document.getElementById('apiKey').value;
            
            if (config.apiType === 'anthropic') {
                config.model = document.getElementById('modelSelect').value;
            } else if (config.apiType === 'openai') {
                config.model = document.getElementById('openaiModelSelect')?.value || 'gpt-4o';
            }

            localStorage.setItem('cpa-config', JSON.stringify(config));
            hideConfig();
            showStatus('success', '✅ 配置已保存');
        }

        // 显示/隐藏配置
        function showConfig() {
            document.getElementById('configModal').classList.add('show');
        }

        function hideConfig() {
            document.getElementById('configModal').classList.remove('show');
        }

        // 更新 API 配置显示
        function updateApiConfig() {
            const apiType = document.getElementById('apiType').value;
            const gatewayGroup = document.getElementById('gatewayGroup');
            const apiKeyGroup = document.getElementById('apiKeyGroup');
            const modelGroup = document.getElementById('modelGroup');

            gatewayGroup.style.display = 'none';
            apiKeyGroup.style.display = 'none';
            modelGroup.style.display = 'none';

            if (apiType === 'openclaw') {
                gatewayGroup.style.display = 'block';
            } else if (apiType === 'anthropic') {
                apiKeyGroup.style.display = 'block';
                modelGroup.style.display = 'block';
                document.getElementById('modelSelect').innerHTML = `
                    <option value="claude-3-5-sonnet-20241022">Claude 3.5 Sonnet（推荐）</option>
                    <option value="claude-3-opus-20240229">Claude 3 Opus</option>
                    <option value="claude-3-haiku-20240307">Claude 3 Haiku（快速）</option>
                `;
            } else if (apiType === 'openai') {
                apiKeyGroup.style.display = 'block';
                modelGroup.style.display = 'block';
                document.getElementById('modelSelect').innerHTML = `
                    <option value="gpt-4o">GPT-4o（推荐）</option>
                    <option value="gpt-4-turbo">GPT-4 Turbo</option>
                    <option value="gpt-3.5-turbo">GPT-3.5 Turbo（快速）</option>
                `;
            }
        }

        // 加载历史记录
        function loadHistory() {
            const history = JSON.parse(localStorage.getItem('cpa-history') || '[]');
            const historyList = document.getElementById('historyList');

            if (history.length === 0) {
                historyList.innerHTML = `
                    <li style="padding: 20px; text-align: center; color: #999;">
                        暂无历史记录
                    </li>
                `;
                return;
            }

            historyList.innerHTML = history.map((item, index) => `
                <li class="history-item ${currentCompany === item.company ? 'active' : ''}" 
                    onclick="loadHistoryItem(${index})">
                    <div class="icon">📊</div>
                    <div class="content">
                        <div class="company-name">${item.company}</div>
                        <div class="analysis-time">${formatTime(item.timestamp)}</div>
                    </div>
                </li>
            `).join('');
        }

        // 格式化时间
        function formatTime(timestamp) {
            const date = new Date(timestamp);
            const now = new Date();
            const diff = now - date;

            if (diff < 60000) return '刚刚';
            if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';
            if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';
            if (diff < 604800000) return Math.floor(diff / 86400000) + '天前';

            return date.toLocaleDateString('zh-CN');
        }

        // 清空历史
        function clearHistory() {
            if (confirm('确定要清空所有历史记录吗？')) {
                localStorage.removeItem('cpa-history');
                loadHistory();
                showStatus('success', '✅ 历史记录已清空');
            }
        }

        // 新建分析
        function newAnalysis() {
            currentCompany = '';
            document.getElementById('companyInput').value = '';
            document.getElementById('welcomePage').style.display = 'block';
            document.getElementById('resultContainer').style.display = 'none';
            document.getElementById('statusBar').className = 'status-bar';
            document.getElementById('statusBar').innerHTML = '';
            loadHistory();
        }

        // 快速搜索
        function quickSearch(company) {
            document.getElementById('companyInput').value = company;
            startAnalysis();
        }

        // 显示状态
        function showStatus(type, message) {
            const statusBar = document.getElementById('statusBar');
            statusBar.className = 'status-bar show ' + type;
            statusBar.innerHTML = message;
        }

        // 开始分析
        async function startAnalysis() {
            const company = document.getElementById('companyInput').value.trim();
            if (!company) {
                showStatus('error', '❌ 请输入股票名称或代码');
                return;
            }

            currentCompany = company;
            document.getElementById('welcomePage').style.display = 'none';
            showStatus('loading', '<span class="loading-spinner"></span> 正在分析 ' + company + ' 的财务数据，请稍候...');

            const prompt = generateAnalysisPrompt(company);

            try {
                let result;
                if (config.apiType === 'openclaw') {
                    result = await callOpenClawGateway(prompt);
                } else if (config.apiType === 'anthropic') {
                    result = await callAnthropicAPI(prompt);
                } else if (config.apiType === 'openai') {
                    result = await callOpenAIAPI(prompt);
                }

                displayResult(result);
                saveToHistory(company, result);
                loadHistory();
                showStatus('success', '✅ 分析完成！');
            } catch (error) {
                showStatus('error', '❌ 分析失败：' + error.message);
                console.error('Analysis error:', error);
            }
        }

        // 生成分析提示词
        function generateAnalysisPrompt(company) {
            return `你是一位注册会计师（CPA）和资深财务分析师，拥有 20 年的财务分析经验。请对 ${company} 进行全面的财务分析。

**重要要求：**
1. 必须使用 2025 年最新财务数据进行分析
2. 报告必须包含完整的七大章节

**分析报告框架：**

## 一、企业概况
- 公司基本信息、主营业务、发展历程、股权结构、产业链位置、财务简况

## 二、商业模式和经营战略
### 2.1 商业模式画布（九点）
重要合作、关键业务、核心资源、价值主张、客户关系、渠道通路、客户细分、成本结构、收入来源

### 2.2 差异化竞争能力分析
产品差异化、成本差异化、服务差异化、品牌差异化、渠道差异化

## 三、周期性
行业周期性判断、供需分析、历史周期分析

## 四、核心竞争力
分析是否具备：规模经济、网络效应、反定位、转换成本、品牌效应、垄断性资源、流程优势

## 五、财务分析
财务风险、盈利能力、运营能力、现金流分析、成长能力

## 六、估值分析
当前股价验证、分业务板块估值、相对估值对比、估值结论

## 七、投资建议
投资逻辑总结、投资建议（当前价、目标价、止损价）、关键跟踪指标

请开始分析，确保报告完整、专业、准确。`;
        }

        // 调用 OpenClaw Gateway
        async function callOpenClawGateway(prompt) {
            const response = await fetch(config.gatewayUrl + '/api/chat', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    message: prompt,
                    stream: false
                })
            });

            if (!response.ok) {
                throw new Error('Gateway 请求失败: ' + response.status);
            }

            const data = await response.json();
            return data.response || data.message || data.content;
        }

        // 调用 Anthropic API
        async function callAnthropicAPI(prompt) {
            const response = await fetch('https://api.anthropic.com/v1/messages', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'x-api-key': config.apiKey,
                    'anthropic-version': '2023-06-01'
                },
                body: JSON.stringify({
                    model: config.model,
                    max_tokens: 4096,
                    messages: [
                        { role: 'user', content: prompt }
                    ]
                })
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error?.message || 'API 请求失败');
            }

            const data = await response.json();
            return data.content[0].text;
        }

        // 调用 OpenAI API
        async function callOpenAIAPI(prompt) {
            const response = await fetch('https://api.openai.com/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + config.apiKey
                },
                body: JSON.stringify({
                    model: config.model,
                    messages: [
                        { role: 'user', content: prompt }
                    ],
                    max_tokens: 4096
                })
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error?.message || 'API 请求失败');
            }

            const data = await response.json();
            return data.choices[0].message.content;
        }

        // 显示结果
        function displayResult(result) {
            const resultContainer = document.getElementById('resultContainer');
            resultContainer.style.display = 'block';
            resultContainer.innerHTML = marked.parse(result);
        }

        // 保存到历史
        function saveToHistory(company, result) {
            let history = JSON.parse(localStorage.getItem('cpa-history') || '[]');
            
            // 检查是否已存在
            const existingIndex = history.findIndex(item => item.company === company);
            if (existingIndex !== -1) {
                history.splice(existingIndex, 1);
            }

            history.unshift({
                company: company,
                result: result,
                timestamp: new Date().toISOString()
            });

            // 只保留最近 50 条
            if (history.length > 50) {
                history = history.slice(0, 50);
            }

            localStorage.setItem('cpa-history', JSON.stringify(history));
        }

        // 加载历史项
        function loadHistoryItem(index) {
            const history = JSON.parse(localStorage.getItem('cpa-history') || '[]');
            const item = history[index];

            currentCompany = item.company;
            document.getElementById('companyInput').value = item.company;
            document.getElementById('welcomePage').style.display = 'none';
            displayResult(item.result);
            showStatus('success', '✅ 已加载历史记录');
            loadHistory();
        }

        // 初始化
        init();
    </script>
